{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_BASE_URL": "http://192.168.0.7:5500/api",
        "EXPO_PUBLIC_CLOUDINARY_URL": "https://res.cloudinary.com/dd3i7nbiz/image/upload"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_BASE_URL": "https://api.petlink.io.vn/api",
        "EXPO_PUBLIC_CLOUDINARY_URL": "https://res.cloudinary.com/dd3i7nbiz/image/upload"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_BASE_URL": "https://api.petlink.io.vn/api",
        "EXPO_PUBLIC_CLOUDINARY_URL": "https://res.cloudinary.com/dd3i7nbiz/image/upload"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "trinhan2014@icloud.com",
        "ascAppId": "REPLACE-WITH-APP-STORE-CONNECT-APP-ID",
        "appleTeamId": "REPLACE-WITH-TEAM-ID"
      }
    }
  }
}
